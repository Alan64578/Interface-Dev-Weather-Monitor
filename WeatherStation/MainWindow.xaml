<Window x:Class="WeatherStation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Weather Station Comparison - Sherkin Island vs Roches Point"
        Height="860" Width="1260"
        Background="#1E1E1E"
        ResizeMode="CanResize">

    <DockPanel>

        <!-- Top menu -->
        <Menu DockPanel.Dock="Top" Height="36" Background="#2D2D2D" Foreground="White" FontSize="13">
            <MenuItem Header="Load Stations" Foreground="White" Background="#2D2D2D"
                      Click="BtnLoadData_Click"/>
            <MenuItem Header="Plot Stations"  Foreground="#888888" Background="#2D2D2D"
                      x:Name="MenuPlotStations" IsEnabled="False"/>
            <MenuItem Header="Exit Application" Foreground="White" Background="#2D2D2D"
                      Click="MenuExit_Click"/>
        </Menu>

        <!-- Status bar at bottom -->
        <StatusBar DockPanel.Dock="Bottom" Height="24" Background="#2D2D2D">
            <StatusBarItem>
                <TextBlock x:Name="TxtStatus" Text="" Foreground="#AAAAAA" FontSize="11"/>
            </StatusBarItem>
        </StatusBar>

        <!-- Main layout: two station panels left, button panel right -->
        <Grid Background="#1E1E1E" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="0"/>
                <RowDefinition Height="0"/>
            </Grid.RowDefinitions>

            <!-- Sherkin Station panel -->
            <Border Grid.Column="0" Grid.Row="0"
                    BorderBrush="#555555" BorderThickness="1"
                    Margin="0,0,4,0" Background="#2A2A2A">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Sherkin Station"
                               FontWeight="Bold" FontSize="14" Foreground="White"
                               HorizontalAlignment="Center" Margin="0,8,0,6"/>
                    <ListBox x:Name="LstSherkin" Grid.Row="1"
                             Margin="8,0,8,8"
                             Background="#1E1E1E" Foreground="#CCCCCC"
                             BorderBrush="#555555" FontSize="13"
                             MouseDoubleClick="LstSherkin_MouseDoubleClick"/>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="8,0,8,8">
                        <TextBlock Text="Parameter: " Foreground="#AAAAAA" FontSize="12"/>
                        <TextBlock x:Name="TxtSherkinParam" Text="" Foreground="#AAAAAA"
                                   FontStyle="Italic" FontSize="12"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Roches Point Station panel -->
            <Border Grid.Column="1" Grid.Row="0"
                    BorderBrush="#555555" BorderThickness="1"
                    Margin="4,0,4,0" Background="#2A2A2A">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Roches Point Station"
                               FontWeight="Bold" FontSize="14" Foreground="White"
                               HorizontalAlignment="Center" Margin="0,8,0,6"/>
                    <ListBox x:Name="LstRoches" Grid.Row="1"
                             Margin="8,0,8,8"
                             Background="#1E1E1E" Foreground="#CCCCCC"
                             BorderBrush="#555555" FontSize="13"
                             MouseDoubleClick="LstRoches_MouseDoubleClick"/>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="8,0,8,8">
                        <TextBlock Text="Parameter: " Foreground="#AAAAAA" FontSize="12"/>
                        <TextBlock x:Name="TxtRochesParam" Text="" Foreground="#AAAAAA"
                                   FontStyle="Italic" FontSize="12"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Right panel: buttons + count placeholder -->
            <StackPanel Grid.Column="2" Grid.Row="0"
                        Orientation="Vertical" Margin="4,0,0,0">
                <Button x:Name="BtnLoadData" Content="Load Data"
                        Height="36" Margin="0,0,0,6" FontSize="13" FontWeight="Bold"
                        Background="#1A6FC4" Foreground="White" BorderThickness="0"
                        Click="BtnLoadData_Click"/>
                <Button x:Name="BtnPlot" Content="Plot"
                        Height="36" Margin="0,0,0,6" FontSize="13" FontWeight="Bold"
                        Background="#2E9E2E" Foreground="White" BorderThickness="0"
                        IsEnabled="False"/>
                <Button x:Name="BtnRange" Content="Range"
                        Height="36" Margin="0,0,0,12" FontSize="13" FontWeight="Bold"
                        Background="#CC7700" Foreground="White" BorderThickness="0"
                        IsEnabled="False"/>
                <TextBlock Text="Count" Foreground="#AAAAAA" FontSize="12"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Name="TxtCount" Text=""
                           Foreground="#AAAAAA" FontSize="28" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,2,0,4"/>
                <Slider x:Name="SldCount" Minimum="1" Maximum="1"
                        IsEnabled="False" Margin="0,0,0,4"/>
                <TextBlock x:Name="TxtCountRange" Text=""
                           Foreground="#666666" FontSize="11"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>
