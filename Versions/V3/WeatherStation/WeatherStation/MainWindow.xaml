<Window x:Class="WeatherStation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        Title="Weather Station Comparison - Sherkin Island vs Roches Point"
        Height="860" Width="1260"
        Background="#1E1E1E"
        ResizeMode="CanResize">

    <DockPanel>

        <!-- menu bar -->
        <Menu DockPanel.Dock="Top" Height="36" Background="#2D2D2D" Foreground="White" FontSize="13">
            <MenuItem Header="Load Stations" Foreground="White" Background="#2D2D2D"
                      Click="BtnLoadData_Click"/>
            <MenuItem Header="Plot Stations" Foreground="White" Background="#2D2D2D"
                      x:Name="MenuPlotStations" IsEnabled="False"
                      Click="BtnPlot_Click"/>
            <MenuItem Header="Write Differences" Foreground="White" Background="#2D2D2D"
                      x:Name="MenuWriteDiff" IsEnabled="False"
                      Click="MenuWriteDiff_Click"/>
            <MenuItem Header="Exit Application" Foreground="White" Background="#2D2D2D"
                      Click="MenuExit_Click"/>
        </Menu>

        <!-- status bar at the bottom -->
        <StatusBar DockPanel.Dock="Bottom" Height="24" Background="#2D2D2D">
            <StatusBarItem>
                <TextBlock x:Name="TxtStatus" Text="" Foreground="#AAAAAA" FontSize="11"/>
            </StatusBarItem>
        </StatusBar>

        <!-- 2 columns, sidebar on left and charts on right -->
        <Grid Background="#1E1E1E" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- sidebar with the two stations and buttons -->
            <StackPanel Grid.Column="0" Margin="0,0,8,0">

                <!-- sherkin station -->
                <GroupBox Header="Sherkin Station" Foreground="White"
                          FontSize="13" Margin="0,0,0,8">
                    <StackPanel>
                        <ListBox x:Name="LstSherkin"
                                 Margin="4,4,4,4" Height="80"
                                 Background="#1E1E1E" Foreground="#CCCCCC"
                                 BorderBrush="#555555" FontSize="12"
                                 MouseDoubleClick="LstSherkin_MouseDoubleClick"/>

                        <StackPanel Orientation="Horizontal" Margin="4,0,4,4">
                            <TextBlock Text="Selected: " Foreground="#888888" FontSize="11"/>
                            <TextBlock x:Name="TxtSherkinParam" Text=""
                                       Foreground="#4A9EF5" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>

                <!-- roches point station -->
                <GroupBox Header="Roches Point Station" Foreground="White"
                          FontSize="13" Margin="0,0,0,8">
                    <StackPanel>
                        <ListBox x:Name="LstRoches"
                                 Margin="4,4,4,4" Height="80"
                                 Background="#1E1E1E" Foreground="#CCCCCC"
                                 BorderBrush="#555555" FontSize="12"
                                 MouseDoubleClick="LstRoches_MouseDoubleClick"/>

                        <StackPanel Orientation="Horizontal" Margin="4,0,4,4">
                            <TextBlock Text="Selected: " Foreground="#888888" FontSize="11"/>
                            <TextBlock x:Name="TxtRochesParam" Text=""
                                       Foreground="#E05555" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>

                <Separator Margin="0,4,0,10"/>

                <Button x:Name="BtnLoadData" Content="Load Data"
                        Height="36" Margin="0,0,0,6" FontSize="13"
                        Background="#1A6FC4" Foreground="White" BorderThickness="0"
                        Click="BtnLoadData_Click"/>

                <Button x:Name="BtnPlot" Content="Plot"
                        Height="36" Margin="0,0,0,6" FontSize="13"
                        Background="#2E9E2E" Foreground="White" BorderThickness="0"
                        IsEnabled="False"
                        Click="BtnPlot_Click"/>

                <Separator Margin="0,6,0,10"/>

                <!-- count and slider for range -->
                <StackPanel Margin="0,0,0,6">
                    <StackPanel Orientation="Horizontal" Margin="4,4,4,4">
                        <TextBlock Text="Range count: " Foreground="#888888" FontSize="11"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtCount" Text=""
                                   Foreground="#CC7700" FontSize="22" FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <Slider x:Name="SldCount" Minimum="1" Maximum="1"
                        IsEnabled="False" Margin="4,0,4,2"
                        ValueChanged="SldCount_ValueChanged"/>
                <TextBlock x:Name="TxtCountRange" Text=""
                           Foreground="#666666" FontSize="10"
                           HorizontalAlignment="Center" Margin="0,0,0,8"/>

                <Button x:Name="BtnRange" Content="Range"
                        Height="36" Margin="0,0,0,6" FontSize="13"
                        Background="#CC7700" Foreground="White" BorderThickness="0"
                        IsEnabled="False"
                        Click="BtnRange_Click"/>

            </StackPanel>

            <!-- charts go here -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- main plot chart -->
                <Border Grid.Row="0"
                        BorderBrush="#555555" BorderThickness="1"
                        Margin="0,0,0,4" Background="#2A2A2A">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="TxtPlotTitle" Grid.Row="0"
                                   Text="Parameter Chart" Foreground="White"
                                   FontSize="12" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,6,0,4"/>
                        <lvc:CartesianChart x:Name="ChartPlot" Grid.Row="1"
                                            Margin="4" Background="#1E1E1E">
                            <lvc:CartesianChart.AxisX>
                                <lvc:Axis Title="Time" Foreground="#AAAAAA"/>
                            </lvc:CartesianChart.AxisX>
                            <lvc:CartesianChart.AxisY>
                                <lvc:Axis Title="Value" Foreground="#AAAAAA"/>
                            </lvc:CartesianChart.AxisY>
                        </lvc:CartesianChart>
                    </Grid>
                </Border>

                <!-- range chart, shows first N readings -->
                <Border Grid.Row="1"
                        BorderBrush="#555555" BorderThickness="1"
                        Margin="0,4,0,0" Background="#2A2A2A">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="TxtRangeTitle" Grid.Row="0"
                                   Text="Range Chart" Foreground="White"
                                   FontSize="12" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,6,0,4"/>
                        <lvc:CartesianChart x:Name="ChartRange" Grid.Row="1"
                                            Margin="4" Background="#1E1E1E">
                            <lvc:CartesianChart.AxisX>
                                <lvc:Axis Title="Time" Foreground="#AAAAAA"/>
                            </lvc:CartesianChart.AxisX>
                            <lvc:CartesianChart.AxisY>
                                <lvc:Axis Title="Value" Foreground="#AAAAAA"/>
                            </lvc:CartesianChart.AxisY>
                        </lvc:CartesianChart>
                    </Grid>
                </Border>

            </Grid>

        </Grid>
    </DockPanel>
</Window>
